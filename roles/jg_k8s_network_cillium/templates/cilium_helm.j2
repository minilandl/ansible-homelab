apiVersion: cilium.io/v2alpha1


# values.yaml
namespace: kube-system

# Connectivity & Routing
tunnel: disabled
routingMode: native
autoDirectNodeRoutes: true
ipv4NativeRoutingCIDR: "10.42.0.0/16"
ipv4:
  enabled: true

# IPAM (IP Address Management)
ipam:
  operator:
    clusterPoolIPv4PodCIDRList: ["10.42.0.0/16"]

# BGP & Load Balancing
bgpControlPlane:
  enabled: true
loadBalancer:
  mode: dsr

# Kube-Proxy Replacement
kubeProxyReplacement: true
k8sServiceHost: "jg-k8smaster1.jaspergreenhill.com"
k8sServicePort: 6443

# Monitoring & Hubble
prometheus:
  enabled: true
operator:
  prometheus:
    enabled: true
hubble:
  enabled: true
  metrics:
    enabled:
      - dns
      - drop
      - tcp
      - flow
      - port-distribution
      - icmp
      - http
